# Copy to .vulle/profiles/bank-a.env and replace placeholders.
# Never commit the resulting profile file.
#
# A profile may contain the complete runtime configuration: Jira, Confluence,
# LLM, embedding, Qdrant, TLS, and RAG scope. Values in this file override the
# root .env when commands run with --profile bank-a.
JIRA_BASE_URL=https://bank-a.atlassian.net
JIRA_EMAIL=security-review@example.com
JIRA_API_TOKEN=replace-me
JIRA_AUTH_MODE=basic
JIRA_API_VERSION=3
JIRA_ACCEPTANCE_CRITERIA_FIELD=

CONFLUENCE_BASE_URL=https://bank-a.atlassian.net/wiki
CONFLUENCE_EMAIL=security-review@example.com
CONFLUENCE_API_TOKEN=replace-me
CONFLUENCE_AUTH_MODE=basic

# Use the institution CA bundle if HTTPS is intercepted by a corporate proxy.
HTTP_VERIFY_SSL=true
HTTP_CA_BUNDLE=/secure/path/bank-ca-chain.pem

# Mask common PII before embedding and LLM analysis for this target.
PII_REDACTION_MODE=mask

# OpenAI-compatible local or internal LLM service.
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=local-not-needed
LLM_MODEL=gpt-oss-120b
LLM_TEMPERATURE=0.1
LLM_JSON_REPAIR_ATTEMPTS=1
LLM_HTTP_RETRIES=2

# OpenAI-compatible embedding service. EMBEDDING_DIMENSIONS must match the
# vector size returned by the selected embedding model.
EMBEDDING_BASE_URL=http://127.0.0.1:8000/v1
EMBEDDING_API_KEY=local-not-needed
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=600

# Qdrant vector database. Use QDRANT_PATH for Docker-free local storage, or use
# QDRANT_URL when Qdrant runs as a service on the same/another approved host.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_PATH=.vulle/qdrant_local
QDRANT_COLLECTION=vulle_bank_a_knowledge
QDRANT_UPSERT_BATCH_SIZE=128

# Isolate target-specific knowledge by tenant, environment, and knowledge base.
RAG_TENANT_ID=bank-a
RAG_ENVIRONMENT=preprod
RAG_KNOWLEDGE_BASE_ID=bank-a-security-v1
RAG_TOP_K=6
RAG_MAX_CONTEXT_CHARS=8000
RAG_MAX_CHUNKS_PER_SOURCE=3
RAG_CANDIDATE_MULTIPLIER=4
RAG_DENSE_WEIGHT=0.65
RAG_LEXICAL_WEIGHT=0.20
RAG_SOURCE_WEIGHT=0.15
RAG_INDEX_RETRY_COUNT=3
RAG_INDEX_RETRY_BASE_DELAY_SECONDS=1
RAG_MAX_FILE_SIZE_MB=10
RAG_MAX_TOTAL_FILES=10000
RAG_MAX_CHUNKS_PER_DOCUMENT=500
RAG_FOLLOW_SYMLINKS=false
RAG_INDEX_SCHEMA_VERSION=2
